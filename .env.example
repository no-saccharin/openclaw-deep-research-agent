# ============ LLM 配置（三选一） ============
# 方案 A: 通义千问（推荐，阿里云部署）
LLM_PROVIDER=dashscope
# 推荐用法 1：引用外部环境变量
DASHSCOPE_API_KEY=env:OPENCLAW_DASHSCOPE_API_KEY
# 推荐用法 2：引用系统密钥环
# DASHSCOPE_API_KEY=keyring:openclaw-deep-research-agent/dashscope_api_key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_SEARCH=qwen3-max
LLM_MODEL_SPECIALIST=qwen3.5-plus
LLM_MODEL_RESPONSE=qwen3-max

# 方案 B: OpenAI
# LLM_PROVIDER=openai
# OPENAI_API_KEY=env:OPENCLAW_OPENAI_API_KEY
# LLM_MODEL_SEARCH=gpt-4o
# LLM_MODEL_SPECIALIST=gpt-4o-mini
# LLM_MODEL_RESPONSE=gpt-4o

# 方案 C: 本地 Ollama
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# LLM_MODEL_SEARCH=qwen2.5:14b
# LLM_MODEL_SPECIALIST=qwen2.5:14b
# LLM_MODEL_RESPONSE=qwen2.5:14b

# ============ 搜索工具 API ============
# BrightData（主搜索，必填）
BRIGHT_DATA_API_TOKEN=env:OPENCLAW_BRIGHTDATA_API_TOKEN

# FireCrawl（补充搜索，推荐填写）
FIRECRAWL_API_KEY=env:OPENCLAW_FIRECRAWL_API_KEY

# Stagehand（浏览器自动化，可选）
STAGEHAND_ENABLED=false
MODEL_API_KEY=env:OPENCLAW_STAGEHAND_MODEL_API_KEY

# ============ 服务配置 ============
API_HOST=0.0.0.0
API_PORT=8088
LOG_LEVEL=INFO
SQLITE_DB_PATH=./data/research_history.db

# ============ Telegram Bot（可选） ============
TELEGRAM_BOT_TOKEN=env:OPENCLAW_TELEGRAM_BOT_TOKEN
TELEGRAM_ALLOWED_USERS=